# Copy to .env. Get these values by running `terraform apply` in
# deploy/terraform/cognito and reading its outputs.
#
# Used two ways:
#  - `npm run dev` / `npm run build` (no Docker): Vite reads this file
#    directly and exposes the values via import.meta.env.
#  - `docker compose up`: Compose auto-loads this file (it must stay named
#    .env at the repo root) and substitutes these into the container's
#    runtime environment (see docker-compose.yml) - NOT into the image
#    build, so changing values here just needs a container restart.
#
# Kubernetes/Helm deployments don't use this file at all - see the
# "Authentication" section in README.md for the Helm equivalent.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=us-east-1
